# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="WhatsApp Micro ERP"
DEBUG=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used automatically by docker-compose; override for external DBs
DATABASE_URL=postgresql://erp_user:erp_pass@db:5432/whatsapp_erp

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=my_verify_token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Daraja / M-Pesa ───────────────────────────────────────────────────────────
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=https://yourdomain.example.com/mpesa/callback
# Use https://api.safaricom.co.ke for production
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke
